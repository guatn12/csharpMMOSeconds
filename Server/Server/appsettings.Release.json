{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}],
          { "Message": "lj" },
          { "NewLine" },
          { "Exception" },
          "
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/server.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 104857600,
          "retainedFileCountLimit": 30,
          "buffered": true,
          "flushToDiskInterval": "00:00:05",
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}],
          { "Message": "lj" },
          { "NewLine" },
          { "Exception" },
          "
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/error-.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 52428800,
          "retainedFileCountLimit": 90,
          "restrictedToMinimumLevel": "Error",
          "buffered": false,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}],
          { "SourceContext" },
          { "NewLine" },
          { "Message": "lj" },
          { "NewLine" },
          { "Exception" },
          { "NewLine" },
          "
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "ServerSettings": {
    "Network": {
      "Host": "0.0.0.0",
      "Port": 7777,
      "ListenBacklog": 1000
    },
    "Logging": {
      "Level": "Warning",
      "EnableConsole": false,
      "EnableFile": true,
      "FilePath": "/var/log/mmo-server/server.log"
    },
    "GameData": {
      "DataPath": "GameData",
      "EnableHotReload": false
    },
    "JobQueue": {
      "WorkerThreadCount": 8,
      "MaxQueueSize": 50000,
      "QueueTimeoutMs": 10000
    },
    "Session": {
      "HeartbeatIntervalMs": 30000,
      "TimeoutMs": 120000
    },
    "Tick": {
      "BaseTickMs": 16
    },
    "Room": {
      "MaxRooms": 1000,
      "MaxRoomNameLength": 100,
      "EmptyRoomCleanupIntervalMinutes": 10,
      "TickIntervalMs": 16,
      "Lobby": {
        "MaxPlayers": 500,
        "DefaultName": "Main Lobby"
      },
      "Battle": {
        "MaxPlayers": 50
      },
      "Dungeon": {
        "MaxPlayers": 20
      },
      "Guild": {
        "MaxPlayers": 200
      },
      "Private": {
        "MaxPlayers": 100
      }
    }
  }
}