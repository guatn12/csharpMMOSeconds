{
  "ServerConfiguration": {
    "Network": {
      "Host": "0.0.0.0",
      "Port": 7777,
      "ListenBacklog": 100
    },
    "Logging": {
      "Level": "Information",
      "Format": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
      "OutputPath": "logs/server-.log",
      "EnableConsoleLogging": true,
      "EnableFileLogging": true,
      "MaxLogFiles": 30,
      "MaxLogFileSizeMB": 50
    },
    "Security": {
      "TokenExpirationMinutes": 60,
      "EnableEncryption": false,
      "EnableRateLimiting": true,
      "MaxRequestsPerMinute": 100
    },
    "Database": {
      "MaxPoolSize": 100,
      "MinPoolSize": 5,
      "ConnectionTimeoutSeconds": 30,
      "CommandTimeoutSeconds": 30,
      "EnableConnectionPooling": true,
      "EnableRetryOnFailure": true,
      "MaxRetryCount": 3
    },
    "JobQueue": {
      "WorkerThreadCount": 0,
      "MaxQueueSize": 10000,
      "QueueCheckIntervalMs": 100,
      "CleanupTimerIntervalMs": 5000,
      "EnablePriorityQueue": false,
      "EnableJobStatistics": true,
      "ShutdownTimeoutSeconds": 30
    },
    "GameData": {
      "DataPath": "GameData",
      "FileExtension": ".json",
      "EnableHotReload": false,
      "HotReloadDebounceMs": 500
    },
    "Room": {
      "Default": {
        "MaxPlayers": 100,
        "MaxRoomNameLength": 50,
        "AutoStart": true
      },
      "Lobby": {
        "MaxPlayers": 1000,
        "DefaultLobbyName": "Main Lobby",
        "AutoCreateLobby": true,
        "EnableWelcomMessage": true,
        "EnalbeJoinLeaveNotifications": true,
        "ShowLobbyStatus": true,
        "MaxChatMessageLength": 200
      },
      "Battle": {
        "MaxPlayers": 20,
        "AutoMatching": true,
        "TimeLimitMinutes": 30
      },
      "Cleanup": {
        "EmptyRoomCleanupIntervalMinutes": 5,
        "EmptyRoomGracePeriodMinutes": 2,
        "EnalbeAutoCleanup": true
      },
      "Performance": {
        "MaxConcurrentRooms": 1000,
        "MaxJobQueueSize": 1000,
        "BroadcastBatchSize": 50
      },
      "Jobs": {
        "MoveJobTimeoutMs": 3000,
        "ChatJobTimeoutMs": 2000,
        "MaxChatMessageLength": 500,
        "MaxRepeatingChars": 6,
        "MaxCapsPercentage": 0.7,
        "MinMessageLengthForCapsCheck": 10
      }
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": "5242880"
        }
      }
    ]
  }
}