{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/server.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "ServerSettings": {
    "Network": {
      "Host": "127.0.0.1",
      "Port": 7777,
      "ListenBacklog": 10
    },

    "Logging": {
      "Level": "Information",
      "EnableConsole": true,
      "EnableFile": true,
      "FilePath": "logs/server.log"
    },

    "GameData": {
      "DataPath": "GameData",
      "EnableHotReload": true
    },

    "JobQueue": {
      "WorkerThreadCount": 4,
      "MaxQueueSize": 10000,
      "QueueTimeoutMs": 5000
    },

    "Room": {
      "MaxRooms": 100,
      "Lobby": {
        "MaxPlayers": 100,
        "DefaultName": "Main Lobby"
      }
    },
    "Redis": {
      "ConnectionString": "localhost:6379"
    },
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=mmo_db;Username=postgres;Password=1q2w3e4r@!"
    }
  }
}