{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/server.log",
          "rollingInterval": "Day",
          "buffered": false,
          "flushToDiskInterval": "00:00:01",
          "shared": true
        }
      }
    ]
  },

  "ServerSettings": {
    "Network": {
      "Host": "127.0.0.1",
      "Port": 7777,
      "ListenBacklog": 10
    },

    "GameData": {
      "DataPath": "GameData"
    },

    "JobQueue": {
      "WorkerThreadCount": 4,
      "MaxQueueSize": 10000,
      "QueueTimeoutMs": 5000
    },

    "Room": {
      "MaxRooms": 100,
      "MaxRoomNameLength": 50,
      "EmptyRoomCleanupIntervalMinutes": 30,
      "TickIntervalMs": 100,
      "Lobby": {
        "MaxPlayers": 100,
        "DefaultName": "Main Lobby"
      }
    },
    "Redis": {
      "ConnectionString": "redis:6379"
    },
    "Database": {
      
      "MinPoolSize": 15,
      "MaxPoolSize": 100,
      "ConnectionTimeout": 30,
      "CommandTimeout": 15,
      "MaxRetryCount": 3,
      "EnableRetryOnFailure": true,
      "EnableSensitiveDataLogging": false
    }
  }
}