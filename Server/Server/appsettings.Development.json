{
  "ServerSettings": {
    "Network": {
      "Host": "127.0.0.1",
      "Port": 7777,
      "ListenBacklog": 50
    },
    "Logging": {
      "Level": "Debug",
      "EnableConsole": true,
      "EnableFile": true,
      "FilePath": "logs/dev/server.log"
    },
    "GameData": {
      "DataPath": "GameData",
      "EnableHotReload": false
    },
    "JobQueue": {
      "WorkerThreadCount": 2,
      "MaxQueueSize": 1000,
      "QueueTimeoutMs": 5000
    },
    "Room": {
      "MaxRooms": 50,
      "MaxRoomNameLength": 50,
      "EmptyRoomCleanupIntervalMinutes": 30,
      "Lobby": {
        "MaxPlayers": 100,
        "DefaultName": "Dev Lobby"
      },
      "Battle": {
        "MaxPlayers": 10
      },
      "Dungeon": {
        "MaxPlayers": 5
      },
      "Guild": {
        "MaxPlayers": 50
      },
      "Private": {
        "MaxPlayers": 20
      }
    }
  }
}