{
  "ServerConfiguration": {
    "Network": {
      "Port": 5000,
      "ListenBacklog": 50
    },
    "Logging": {
      "Level": "Debug",
      "EnableConsoleLogging": true,
      "EnableFileLogging": true,
      "OutputPath": "logs/dev/server-.log",
      "MaxLogFiles": 10,
      "MaxLogFileSizeMB": 10
    },
    "Security": {
      "EnableEncryption": false,
      "EnableRateLimiting": false,
      "TokenExpirationMinutes": 120
    },
    "Database": {
      //"ConnectionString": "Server=localhost;Database=MMOGameDev;Integrated Security=true;TrustServerCertificate=true;",
      "MaxPoolSize": 20,
      "MinPoolSize": 2,
      "EnableRetryOnFailure": true,
      "MaxRetryCount": 5
    },
    "JobQueue": {
      "WorkerThreadCount": 2,
      "MaxQueueSize": 1000,
      "QueueCheckIntervalMs": 50,
      "EnableJobStatistics": true,
      "EnablePriorityQueue": true
    }
  }
}